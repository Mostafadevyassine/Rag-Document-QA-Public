# Copy to automation/.env and fill in. (.env is gitignored.)
#
#   cp automation/env.example automation/.env

# Shared secret the bot endpoint checks (X-Bot-Secret header).
# Must MATCH the backend's BOT_SHARED_SECRET (see README step 1).
BOT_SHARED_SECRET=pick-a-long-random-string

# The .NET backend as seen from inside the n8n container.
# Mac/Windows Docker Desktop: host.docker.internal. Leave as-is unless your
# backend runs elsewhere.
BACKEND_URL=http://host.docker.internal:5000

# Public HTTPS URL that Telegram uses to reach n8n. Get it by starting a tunnel:
#   cloudflared tunnel --url http://localhost:5678
# then paste the printed https://<random>.trycloudflare.com URL here and restart
# the n8n container. (This URL changes each time the tunnel restarts.)
WEBHOOK_URL=https://your-tunnel-url.trycloudflare.com
